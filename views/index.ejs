<!DOCTYPE html>
<html>
<head>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-4" style="max-width: 600px;">

  <h2 class="text-center mb-4">Prédictions UFC</h2>
   <h3 class="text-center mb-4"><%= data[0].Date %></h3>

  <% data.forEach(fight => { %>

    <div class="row align-items-center border rounded p-3 mb-3 shadow-sm">
      
      <!-- Fighter 1 -->
      <div class="col-5 text-start">
        <strong><%= fight.Fighter1 %></strong>
      </div>

      <!-- Probabilité -->
      <div class="col-2 text-center">
        <span class="badge bg-primary">
          <%= (fight.prob_win_fighter1 * 100).toFixed(1) %>%
        </span>
      </div>

      <!-- Fighter 2 -->
      <div class="col-5 text-end">
        <strong><%= fight.Fighter2 %></strong>
      </div>

    </div>

  <% }) %>

</div>

</body>
</html>